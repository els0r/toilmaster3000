{
  "components": {
    "schemas": {
      "Analytics": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/Analytics.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "assumptions": {
            "$ref": "#/components/schemas/Assumptions"
          },
          "auto_approved": {
            "$ref": "#/components/schemas/Stat"
          },
          "delta_label": {
            "type": "string"
          },
          "human_review": {
            "$ref": "#/components/schemas/Stat"
          },
          "switches_saved": {
            "format": "int64",
            "type": "integer"
          },
          "switches_saved_delta": {
            "$ref": "#/components/schemas/Delta"
          },
          "switches_saved_hours": {
            "format": "double",
            "type": "number"
          },
          "switches_saved_money": {
            "format": "double",
            "type": "number"
          }
        },
        "required": [
          "auto_approved",
          "human_review",
          "switches_saved",
          "switches_saved_hours",
          "switches_saved_money",
          "switches_saved_delta",
          "delta_label",
          "assumptions"
        ],
        "type": "object"
      },
      "Approval": {
        "additionalProperties": false,
        "properties": {
          "approved_at": {
            "format": "date-time",
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "manual": {
            "type": "boolean"
          },
          "matched_rule": {
            "type": "string"
          },
          "number": {
            "format": "int64",
            "type": "integer"
          },
          "state": {
            "enum": [
              "open",
              "merged",
              "closed",
              "unknown"
            ],
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "title_parts": {
            "$ref": "#/components/schemas/TitleParts"
          },
          "url": {
            "type": "string"
          }
        },
        "required": [
          "number",
          "title",
          "title_parts",
          "author",
          "url",
          "matched_rule",
          "manual",
          "state",
          "approved_at"
        ],
        "type": "object"
      },
      "Assumptions": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/Assumptions.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "currency": {
            "description": "Symbol prefixed onto the money figure (seeded \"$\")",
            "minLength": 1,
            "type": "string"
          },
          "hourly_rate": {
            "description": "The user's hourly rate, applied to the time saved (seeded 100)",
            "format": "int64",
            "minimum": 0,
            "type": "integer"
          },
          "minutes_per_switch": {
            "description": "Minutes a single context switch costs (seeded 23)",
            "format": "int64",
            "minimum": 1,
            "type": "integer"
          }
        },
        "required": [
          "minutes_per_switch",
          "hourly_rate",
          "currency"
        ],
        "type": "object"
      },
      "CycleStatus": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/CycleStatus.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "approved_count": {
            "format": "int64",
            "type": "integer"
          },
          "dropped_count": {
            "format": "int64",
            "type": "integer"
          },
          "last_run": {
            "format": "date-time",
            "type": [
              "string",
              "null"
            ]
          },
          "outcome": {
            "type": "string"
          },
          "queue_count": {
            "format": "int64",
            "type": "integer"
          }
        },
        "required": [
          "last_run",
          "outcome",
          "approved_count",
          "queue_count",
          "dropped_count"
        ],
        "type": "object"
      },
      "Delta": {
        "additionalProperties": false,
        "properties": {
          "pct": {
            "format": "double",
            "type": "number"
          },
          "state": {
            "type": "string"
          }
        },
        "required": [
          "pct",
          "state"
        ],
        "type": "object"
      },
      "ErrorDetail": {
        "additionalProperties": false,
        "properties": {
          "location": {
            "description": "Where the error occurred, e.g. 'body.items[3].tags' or 'path.thing-id'",
            "type": "string"
          },
          "message": {
            "description": "Error message text",
            "type": "string"
          },
          "value": {
            "description": "The value at the given location"
          }
        },
        "type": "object"
      },
      "ErrorModel": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/ErrorModel.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "detail": {
            "description": "A human-readable explanation specific to this occurrence of the problem.",
            "examples": [
              "Property foo is required but is missing."
            ],
            "type": "string"
          },
          "errors": {
            "description": "Optional list of individual error details",
            "items": {
              "$ref": "#/components/schemas/ErrorDetail"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "instance": {
            "description": "A URI reference that identifies the specific occurrence of the problem.",
            "examples": [
              "https://example.com/error-log/abc123"
            ],
            "format": "uri",
            "type": "string"
          },
          "status": {
            "description": "HTTP status code",
            "examples": [
              400
            ],
            "format": "int64",
            "type": "integer"
          },
          "title": {
            "description": "A short, human-readable summary of the problem type. This value should not change between occurrences of the error.",
            "examples": [
              "Bad Request"
            ],
            "type": "string"
          },
          "type": {
            "default": "about:blank",
            "description": "A URI reference to human-readable documentation for the error.",
            "examples": [
              "https://example.com/errors/example"
            ],
            "format": "uri",
            "type": "string"
          }
        },
        "type": "object"
      },
      "FileDiff": {
        "additionalProperties": false,
        "properties": {
          "additions": {
            "format": "int64",
            "type": "integer"
          },
          "deletions": {
            "format": "int64",
            "type": "integer"
          },
          "filename": {
            "type": "string"
          },
          "patch": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "filename",
          "status",
          "additions",
          "deletions",
          "patch"
        ],
        "type": "object"
      },
      "ManualApproveOutputBody": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/ManualApproveOutputBody.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "number": {
            "format": "int64",
            "type": "integer"
          },
          "ok": {
            "type": "boolean"
          }
        },
        "required": [
          "ok",
          "number"
        ],
        "type": "object"
      },
      "PRDiffBody": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/PRDiffBody.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "files": {
            "items": {
              "$ref": "#/components/schemas/FileDiff"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "total_files": {
            "format": "int64",
            "type": "integer"
          }
        },
        "required": [
          "files",
          "total_files"
        ],
        "type": "object"
      },
      "QueueItem": {
        "additionalProperties": false,
        "properties": {
          "additions": {
            "format": "int64",
            "type": "integer"
          },
          "author": {
            "type": "string"
          },
          "changed_files": {
            "format": "int64",
            "type": "integer"
          },
          "deletions": {
            "format": "int64",
            "type": "integer"
          },
          "number": {
            "format": "int64",
            "type": "integer"
          },
          "reasons": {
            "items": {
              "type": "string"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "title": {
            "type": "string"
          },
          "title_parts": {
            "$ref": "#/components/schemas/TitleParts"
          },
          "url": {
            "type": "string"
          }
        },
        "required": [
          "number",
          "title",
          "title_parts",
          "author",
          "url",
          "additions",
          "deletions",
          "changed_files",
          "reasons"
        ],
        "type": "object"
      },
      "RuleBody": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/RuleBody.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "authors_exclude": {
            "items": {
              "type": "string"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "authors_include": {
            "items": {
              "type": "string"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "class": {
            "description": "Rule class: approve (default) or review",
            "type": "string"
          },
          "description_exclude": {
            "type": "string"
          },
          "description_include": {
            "type": "string"
          },
          "diff_max": {
            "description": "Upper diff-size bound (additions+deletions); 0 = unconstrained",
            "format": "int64",
            "minimum": 0,
            "type": "integer"
          },
          "diff_min": {
            "description": "Lower diff-size bound (additions+deletions); 0 = unconstrained",
            "format": "int64",
            "minimum": 0,
            "type": "integer"
          },
          "enabled": {
            "description": "Whether the rule contributes matches",
            "type": "boolean"
          },
          "id": {
            "description": "Stable generated id (response only)",
            "readOnly": true,
            "type": "string"
          },
          "name": {
            "description": "Editable rule name",
            "type": "string"
          },
          "scope_exclude": {
            "type": "string"
          },
          "scope_include": {
            "type": "string"
          },
          "type_exclude": {
            "type": "string"
          },
          "type_include": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "Stat": {
        "additionalProperties": false,
        "properties": {
          "count": {
            "format": "int64",
            "type": "integer"
          },
          "delta": {
            "$ref": "#/components/schemas/Delta"
          },
          "share": {
            "format": "double",
            "type": "number"
          }
        },
        "required": [
          "count",
          "share",
          "delta"
        ],
        "type": "object"
      },
      "TitleParts": {
        "additionalProperties": false,
        "properties": {
          "breaking": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "scopes": {
            "items": {
              "type": "string"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "scopes",
          "breaking",
          "description"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "title": "toilmaster3000",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/toilmaster3000/v1/analytics": {
      "get": {
        "operationId": "get-analytics",
        "parameters": [
          {
            "description": "Look-back window: today | week (ISO Monday) | month (calendar 1st) | days (rolling)",
            "explode": false,
            "in": "query",
            "name": "range",
            "schema": {
              "default": "today",
              "description": "Look-back window: today | week (ISO Monday) | month (calendar 1st) | days (rolling)",
              "enum": [
                "today",
                "week",
                "month",
                "days"
              ],
              "type": "string"
            }
          },
          {
            "description": "Rolling-window length in days; required for range=days",
            "explode": false,
            "in": "query",
            "name": "days",
            "schema": {
              "description": "Rolling-window length in days; required for range=days",
              "format": "int64",
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Analytics"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Approval-history analytics for a selectable range (slice 2: time picker)"
      }
    },
    "/api/toilmaster3000/v1/approvals": {
      "get": {
        "operationId": "list-approvals",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/Approval"
                  },
                  "type": [
                    "array",
                    "null"
                  ]
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Approval Feed, newest-first"
      }
    },
    "/api/toilmaster3000/v1/queue": {
      "get": {
        "operationId": "list-queue",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/QueueItem"
                  },
                  "type": [
                    "array",
                    "null"
                  ]
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Needs-Human-Review queue (derived live)"
      }
    },
    "/api/toilmaster3000/v1/queue/{number}/approve": {
      "post": {
        "operationId": "approve-queue-item",
        "parameters": [
          {
            "description": "PR number to approve from the queue",
            "in": "path",
            "name": "number",
            "required": true,
            "schema": {
              "description": "PR number to approve from the queue",
              "format": "int64",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ManualApproveOutputBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Manual override approve (the only path to approve a breaking change)"
      }
    },
    "/api/toilmaster3000/v1/queue/{number}/diff": {
      "get": {
        "operationId": "get-queue-diff",
        "parameters": [
          {
            "description": "PR number whose diff to fetch from the queue",
            "in": "path",
            "name": "number",
            "required": true,
            "schema": {
              "description": "PR number whose diff to fetch from the queue",
              "format": "int64",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PRDiffBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Fetch a queued PR's diff on demand (the Diff card)"
      }
    },
    "/api/toilmaster3000/v1/rules": {
      "get": {
        "operationId": "list-rules",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/RuleBody"
                  },
                  "type": [
                    "array",
                    "null"
                  ]
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "List rules in file order"
      },
      "post": {
        "operationId": "create-rule",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RuleBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuleBody"
                }
              }
            },
            "description": "Created"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Create a rule"
      }
    },
    "/api/toilmaster3000/v1/rules/{id}": {
      "delete": {
        "operationId": "delete-rule",
        "parameters": [
          {
            "description": "Stable rule id",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "description": "Stable rule id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Delete a rule"
      },
      "put": {
        "operationId": "update-rule",
        "parameters": [
          {
            "description": "Stable rule id",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "description": "Stable rule id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RuleBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuleBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Full-replace a rule (also enable/disable)"
      }
    },
    "/api/toilmaster3000/v1/settings": {
      "get": {
        "operationId": "get-settings",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Assumptions"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Read the analytics assumption constants (the chip)"
      },
      "put": {
        "operationId": "update-settings",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Assumptions"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Assumptions"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Full-replace the analytics assumption constants"
      }
    },
    "/api/toilmaster3000/v1/status": {
      "get": {
        "operationId": "get-status",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CycleStatus"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Cycle status line"
      }
    }
  }
}
